# pyenv
#   For a library or app, you might want to share your .python-version if you're using pyenv
#   but suggest keeping it out of git
.python-version

# pipenv
#   According to pypa/pipenv#1263, pipenv should generally have its Pipfile.lock in git
#   unless you are developing a library.
#   For this application, we can keep lock files in git.

# poetry
#   Similarly, poetry.lock is usually committed.

# pdm
#   If using pdm, .pdm.toml is local-only
.pdm.toml
.pdm-plugins/

# venv
#   Virtual environments
.venv/
venv/
ENV/
env/
active_env/

